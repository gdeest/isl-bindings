executable isl-test
  main-is:             Main.hs
  -- other-modules:
  -- other-extensions:
  build-depends:       base >=4.12.0.0 && <5,
                       isl-bindings,
                       isl-bindings-hl,
                       ghc-typelits-natnormalise
  ghc-options:         -O2 -fplugin GHC.TypeLits.Normalise -Wall -Wno-incomplete-uni-patterns
  hs-source-dirs:      src
  default-language:    Haskell2010

