test-suite isl-tests
  type:                exitcode-stdio-1.0
  main-is:             Main.hs
  other-modules:       Test.Generators,
                       Test.Helpers,
                       Test.BasicSet,
                       Test.Set,
                       Test.BasicMap,
                       Test.Map,
                       Test.Scan,
                       Test.Multi,
                       Test.MultiAff,
                       Test.PwAff,
                       Test.Div
  hs-source-dirs:      test
  build-depends:       base >=4.12.0.0 && <5,
                       isl-bindings,
                       isl-bindings-hl,
                       isl-scan,
                       deepseq,
                       tasty,
                       tasty-hunit,
                       tasty-quickcheck,
                       QuickCheck
  ghc-options:         -O2 -Wall
  default-language:    Haskell2010
